---
// NekoBeat Landing Page — generated from Stitch, polished and integrated into Astro
const base = import.meta.env.BASE_URL;
---

<html class="dark" lang="en">
<head>
	<meta charset="utf-8" />
	<meta content="width=device-width, initial-scale=1.0" name="viewport" />

	<!-- Primary SEO -->
	<title>NekoBeat — The Premium, Cross-Platform Music Aggregator</title>
	<meta name="description" content="NekoBeat is a free, open-source music aggregator built with Rust, Tauri v2, React, and GStreamer. Features 10-band DSP equalizer, offline caching, YouTube/SoundCloud search, synced lyrics, and Discord Rich Presence. Under 12ms latency, under 150MB memory." />
	<meta name="keywords" content="NekoBeat, music aggregator, Rust, Tauri, GStreamer, yt-dlp, equalizer, cross-platform, open source, desktop music player, offline music, DSP equalizer" />
	<meta name="author" content="Nishal" />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href="https://nishal21.github.io/NekoBeat-Website/" />

	<!-- Open Graph / Facebook -->
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://nishal21.github.io/NekoBeat-Website/" />
	<meta property="og:title" content="NekoBeat — The Premium, Cross-Platform Music Aggregator" />
	<meta property="og:description" content="Free, open-source music aggregator built with Rust, Tauri v2, React, and GStreamer. Audiophile-grade streaming with 10-band DSP equalizer, offline caching, and under 12ms latency." />
	<meta property="og:image" content="https://nishal21.github.io/NekoBeat-Website/screenshots/player_expanded.png" />
	<meta property="og:image:width" content="1920" />
	<meta property="og:image:height" content="1080" />
	<meta property="og:site_name" content="NekoBeat" />
	<meta property="og:locale" content="en_US" />

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="NekoBeat — The Premium Music Aggregator" />
	<meta name="twitter:description" content="Open-source music aggregator powered by Rust & GStreamer. 10-band equalizer, offline caching, synced lyrics." />
	<meta name="twitter:image" content="https://nishal21.github.io/NekoBeat-Website/screenshots/player_expanded.png" />

	<!-- Favicon & Icons -->
	<link rel="icon" type="image/png" href={`${base}screenshots/logo.png`} />
	<link rel="apple-touch-icon" href={`${base}screenshots/logo.png`} />

	<!-- GEO: AI Discoverability -->
	<link rel="llms" href={`${base}llms.txt`} type="text/plain" title="LLM Context" />

	<!-- Preconnect for performance -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
	<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

	<!-- JSON-LD Structured Data: SoftwareApplication -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		"name": "NekoBeat",
		"description": "A free, open-source, cross-platform music aggregator built with Rust, Tauri v2, React, and GStreamer. Features 10-band DSP equalizer, offline caching, YouTube/SoundCloud aggregation, synchronized lyrics, and Discord Rich Presence.",
		"url": "https://nishal21.github.io/NekoBeat-Website",
		"applicationCategory": "MultimediaApplication",
		"operatingSystem": "Windows",
		"offers": {
			"@type": "Offer",
			"price": "0",
			"priceCurrency": "USD"
		},
		"softwareVersion": "1.0.0",
		"releaseNotes": "Lyrics & Liberation — Custom lyrics support with .lrc/.srt/.vtt auto-conversion",
		"downloadUrl": "https://github.com/nishal21/NekoBeat/releases/latest",
		"screenshot": "https://nishal21.github.io/NekoBeat-Website/screenshots/player_expanded.png",
		"author": {
			"@type": "Person",
			"name": "Nishal",
			"url": "https://github.com/nishal21"
		},
		"sourceOrganization": {
			"@type": "Organization",
			"name": "NekoBeat",
			"url": "https://nishal21.github.io/NekoBeat-Website",
			"logo": "https://nishal21.github.io/NekoBeat-Website/screenshots/logo.png",
			"sameAs": [
				"https://github.com/nishal21/NekoBeat"
			]
		},
		"featureList": [
			"Universal music aggregation (YouTube, SoundCloud)",
			"10-band GStreamer DSP equalizer (31Hz–16kHz)",
			"Offline caching for liked songs",
			"Synchronized lyrics (.lrc, .srt, .vtt)",
			"Discord Rich Presence",
			"Smart discovery via Last.fm trending",
			"Under 12ms playback latency",
			"Under 150MB memory usage"
		],
		"license": "https://opensource.org/licenses/MIT"
	}
	</script>

	<!-- JSON-LD Structured Data: WebSite -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": "NekoBeat",
		"url": "https://nishal21.github.io/NekoBeat-Website",
		"description": "Official website for NekoBeat, the premium cross-platform music aggregator."
	}
	</script>

	<!-- JSON-LD Structured Data: BreadcrumbList -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": "Home",
				"item": "https://nishal21.github.io/NekoBeat-Website/"
			}
		]
	}
	</script>

	<style is:global>
		.material-symbols-outlined {
			font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
		}

		:root {
			--surface-dim: #131318;
			--surface: #131318;
			--surface-container-lowest: #0e0e13;
			--surface-container-low: #1b1b20;
			--surface-container: #1f1f25;
			--surface-container-high: #2a292f;
			--surface-container-highest: #35343a;
			--primary: #ffb3b6;
			--primary-container: #e11d48;
			--secondary: #4cd7f6;
			--secondary-container: #03b5d3;
			--on-surface: #e4e1e9;
			--on-primary-container: #fffaf9;
			--outline-variant: #5c3f40;
		}

		* { margin: 0; padding: 0; box-sizing: border-box; }

		html {
			scroll-behavior: smooth;
		}

		body {
			background-color: var(--surface);
			color: var(--on-surface);
			font-family: 'Manrope', sans-serif;
			overflow-x: hidden;
			line-height: 1.6;
		}

		.font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }

		/* Hero gradient effect */
		.hero-gradient {
			background: radial-gradient(circle at center, rgba(225, 29, 72, 0.15) 0%, rgba(19, 19, 24, 0) 70%);
		}

		/* Grid background pattern */
		.tech-grid {
			background-image:
				linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
				linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
			background-size: 40px 40px;
		}

		/* Glassmorphic navbar */
		.glass-nav {
			background: rgba(53, 52, 58, 0.6);
			backdrop-filter: blur(24px);
			-webkit-backdrop-filter: blur(24px);
			border: 1px solid rgba(255, 255, 255, 0.06);
		}

		/* Feature cards */
		.feature-card {
			background: rgba(27, 27, 32, 0.8);
			backdrop-filter: blur(12px);
			border: 1px solid rgba(255, 255, 255, 0.05);
			transition: background-color 0.3s ease, transform 0.3s ease;
		}
		.feature-card:hover {
			background: var(--surface-container);
			transform: translateY(-4px);
		}
		.feature-card .card-icon {
			transition: transform 0.3s ease;
		}
		.feature-card:hover .card-icon {
			transform: scale(1.1);
		}

		/* Buttons */
		.btn-primary {
			background: var(--primary-container);
			color: var(--on-primary-container);
			border: none;
			padding: 1rem 2rem;
			border-radius: 12px;
			font-weight: 700;
			font-size: 1.125rem;
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			box-shadow: 0 8px 32px rgba(225, 29, 72, 0.2);
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}
		.btn-primary:hover { transform: scale(1.05); box-shadow: 0 12px 40px rgba(225, 29, 72, 0.3); }
		.btn-primary:active { transform: scale(0.95); }

		.btn-ghost {
			background: rgba(255, 255, 255, 0.05);
			backdrop-filter: blur(12px);
			color: var(--on-surface);
			border: 1px solid rgba(255, 255, 255, 0.1);
			padding: 1rem 2rem;
			border-radius: 12px;
			font-weight: 700;
			font-size: 1.125rem;
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			transition: background 0.2s ease, transform 0.2s ease;
		}
		.btn-ghost:hover { background: rgba(255, 255, 255, 0.1); }
		.btn-ghost:active { transform: scale(0.95); }

		.btn-nav {
			background: var(--primary-container);
			color: var(--on-primary-container);
			border: none;
			padding: 0.625rem 1.5rem;
			border-radius: 12px;
			font-weight: 700;
			font-size: 0.875rem;
			cursor: pointer;
			transition: transform 0.2s ease;
		}
		.btn-nav:active { transform: scale(0.95); }

		/* Tech badge */
		.tech-badge {
			padding: 0.5rem 1.25rem;
			border-radius: 9999px;
			font-weight: 700;
			font-size: 0.875rem;
			letter-spacing: 0.025em;
			border: 1px solid rgba(255, 255, 255, 0.1);
			background: rgba(255, 255, 255, 0.05);
			color: #cbd5e1;
			transition: transform 0.2s ease, background 0.2s ease;
			cursor: default;
		}
		.tech-badge:hover { transform: translateY(-2px); }
		.tech-badge.primary {
			background: rgba(225, 29, 72, 0.1);
			border-color: rgba(225, 29, 72, 0.2);
			color: var(--primary);
		}
		.tech-badge.secondary {
			background: rgba(3, 181, 211, 0.1);
			border-color: rgba(3, 181, 211, 0.2);
			color: var(--secondary);
		}

		/* Nav links */
		.nav-link {
			color: #64748b;
			font-size: 0.875rem;
			font-weight: 600;
			text-decoration: none;
			transition: color 0.3s ease;
			padding: 0.25rem 0;
		}
		.nav-link:hover { color: #fb7185; }
		.nav-link.active {
			color: #fb7185;
			border-bottom: 2px solid #e11d48;
			padding-bottom: 0.25rem;
		}

		/* Section divider */
		.section-divider {
			height: 1px;
			background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
		}

		/* Scroll reveal */
		.reveal {
			opacity: 0;
			transform: translateY(30px);
			transition: opacity 0.8s ease, transform 0.8s ease;
		}
		.reveal.visible {
			opacity: 1;
			transform: translateY(0);
		}

		/* Mobile menu */
		.mobile-menu {
			display: none;
			position: fixed;
			top: 80px;
			left: 5%;
			right: 5%;
			background: rgba(31, 31, 37, 0.95);
			backdrop-filter: blur(24px);
			border: 1px solid rgba(255,255,255,0.06);
			border-radius: 16px;
			padding: 1.5rem;
			z-index: 49;
			flex-direction: column;
			gap: 1rem;
		}
		.mobile-menu.open { display: flex; }

		/* Container */
		.container { max-width: 80rem; margin: 0 auto; padding: 0 1.5rem; }

		/* Architecture image overlay */
		.arch-image-overlay {
			background: linear-gradient(to top-right, var(--surface-dim), transparent, rgba(225, 29, 72, 0.1));
		}

		/* App preview fade */
		.preview-fade {
			background: linear-gradient(to top, var(--surface-container-low), transparent);
		}

		/* Footer link */
		.footer-link {
			color: #64748b;
			text-decoration: none;
			font-size: 0.875rem;
			transition: color 0.3s ease;
		}
		.footer-link:hover { color: #22d3ee; }

		/* Screenshot showcase */
		.screenshot-carousel {
			display: flex;
			gap: 1.5rem;
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			padding-bottom: 1rem;
			scrollbar-width: thin;
			scrollbar-color: rgba(255,255,255,0.15) transparent;
		}
		.screenshot-carousel::-webkit-scrollbar { height: 6px; }
		.screenshot-carousel::-webkit-scrollbar-track { background: transparent; }
		.screenshot-carousel::-webkit-scrollbar-thumb {
			background: rgba(255,255,255,0.15);
			border-radius: 3px;
		}
		.screenshot-item {
			flex: 0 0 min(80%, 700px);
			scroll-snap-align: center;
			border-radius: 16px;
			overflow: hidden;
			border: 1px solid rgba(255,255,255,0.06);
			box-shadow: 0 20px 40px rgba(0,0,0,0.4);
			transition: transform 0.3s ease;
			position: relative;
		}
		.screenshot-item:hover { transform: scale(1.02); }
		.screenshot-item img {
			width: 100%;
			height: auto;
			display: block;
		}
		.screenshot-label {
			position: absolute;
			bottom: 0;
			left: 0;
			right: 0;
			padding: 1.5rem 1.25rem 1rem;
			background: linear-gradient(to top, rgba(14,14,19,0.9), transparent);
			font-weight: 700;
			font-size: 0.9375rem;
		}
		.screenshot-label span {
			color: #94a3b8;
			font-weight: 400;
			font-size: 0.8125rem;
			display: block;
			margin-top: 0.25rem;
		}

		/* Platform badges */
		.platform-badge {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.5rem 1rem;
			border-radius: 9999px;
			font-size: 0.8125rem;
			font-weight: 600;
			border: 1px solid rgba(255,255,255,0.1);
			background: rgba(255,255,255,0.04);
			color: #94a3b8;
		}
		.platform-badge.available {
			border-color: rgba(225, 29, 72, 0.3);
			background: rgba(225, 29, 72, 0.08);
			color: var(--primary);
		}

		/* Responsive */
		@media (max-width: 768px) {
			.desktop-nav { display: none !important; }
			.mobile-toggle { display: flex !important; }
		}
		@media (min-width: 769px) {
			.mobile-toggle { display: none !important; }
		}

		@media (prefers-reduced-motion: reduce) {
			.reveal { transition: none; opacity: 1; transform: none; }
			.btn-primary:hover, .btn-ghost:hover, .feature-card:hover { transform: none; }
			.screenshot-item:hover { transform: none; }
		}
	</style>
</head>
<body>

	<!-- Navigation -->
	<nav class="glass-nav" style="position:fixed; top:16px; left:50%; transform:translateX(-50%); width:90%; max-width:80rem; border-radius:16px; display:flex; justify-content:space-between; align-items:center; padding:1rem 2rem; z-index:50;">
		<a href="/" style="text-decoration:none; display:flex; align-items:center; gap:0.5rem;">
			<img src={`${base}screenshots/logo.png`} alt="NekoBeat" style="width:32px; height:32px; border-radius:8px;" />
			<span class="font-headline" style="font-size:1.25rem; font-weight:800; color:#f1f5f9; letter-spacing:-0.025em;">
				<span style="color:#e11d48;">Neko</span>Beat
			</span>
		</a>
		<div class="desktop-nav" style="display:flex; align-items:center; gap:2rem;">
			<a class="nav-link active" href="#features">Features</a>
			<a class="nav-link" href="#architecture">Architecture</a>
			<a class="nav-link" href="#download">Download</a>
		</div>
		<div style="display:flex; align-items:center; gap:0.75rem;">
			<a href="https://github.com/nishal21/NekoBeat/releases/latest" class="btn-nav" style="text-decoration:none;">Download</a>
			<button class="mobile-toggle" aria-label="Toggle menu" id="menuToggle" style="background:none; border:none; color:#e4e1e9; cursor:pointer; padding:0.5rem;">
				<span class="material-symbols-outlined" style="font-size:28px;">menu</span>
			</button>
		</div>
	</nav>

	<!-- Mobile menu -->
	<div class="mobile-menu" id="mobileMenu">
		<a class="nav-link" href="#features" style="font-size:1rem;">Features</a>
		<a class="nav-link" href="#architecture" style="font-size:1rem;">Architecture</a>
		<a class="nav-link" href="#download" style="font-size:1rem;">Download</a>
		<a href="https://github.com/nishal21/NekoBeat" class="nav-link" style="font-size:1rem;">GitHub</a>
	</div>

	<!-- Hero Section -->
	<section style="position:relative; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding-top:6rem; overflow:hidden;">
		<div class="tech-grid" style="position:absolute; inset:0; opacity:0.4;"></div>
		<div class="hero-gradient" style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:800px; height:800px; pointer-events:none;"></div>

		<div class="reveal" style="position:relative; z-index:10; max-width:56rem; padding:0 1.5rem; text-align:center;">
			<h1 class="font-headline" style="font-size:clamp(2.5rem, 6vw, 4.5rem); font-weight:800; letter-spacing:-0.04em; color:var(--on-surface); margin-bottom:1.5rem; line-height:1.05;">
				The Premium<br/>Music Aggregator
			</h1>
			<p style="font-size:clamp(1rem, 2vw, 1.25rem); color:#94a3b8; max-width:40rem; margin:0 auto 2.5rem; line-height:1.7;">
				NekoBeat combines the safety of <strong style="color:var(--primary);">Rust</strong>, the fluidity of <strong style="color:var(--secondary);">React</strong>, and the power of <strong style="color:#74d8bd;">GStreamer</strong> to deliver audiophile-grade streaming without the bloat.
			</p>
			<div style="display:flex; flex-wrap:wrap; justify-content:center; gap:1rem;">
				<a href="https://github.com/nishal21/NekoBeat/releases/latest" class="btn-primary" style="text-decoration:none;">
					<span class="material-symbols-outlined">download</span>
					Download for Windows
				</a>
				<a href="https://github.com/nishal21/NekoBeat" class="btn-ghost" style="text-decoration:none;" target="_blank" rel="noopener noreferrer">
					<span class="material-symbols-outlined">code</span>
					View on GitHub
				</a>
			</div>
		</div>

		<!-- App Preview -->
		<div class="reveal" style="position:relative; margin-top:5rem; width:100%; max-width:72rem; padding:0 1.5rem;">
			<div style="background:var(--surface-container-low); border-radius:16px; padding:0.5rem; box-shadow:0 25px 50px rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.05); overflow:hidden; position:relative;">
				<img
					alt="NekoBeat desktop app — expanded player view with album art, synced lyrics, and playback controls"
					style="width:100%; border-radius:12px; display:block;"
					src={`${base}screenshots/player_expanded.png`}
				/>
			</div>
		</div>
	</section>

	<!-- Features Section -->
	<section id="features" style="padding:8rem 0; position:relative; z-index:10;">
		<div class="container">
			<div class="reveal" style="display:flex; flex-wrap:wrap; justify-content:space-between; align-items:flex-end; gap:1.5rem; margin-bottom:4rem;">
				<div style="max-width:36rem;">
					<p style="color:var(--secondary); font-weight:700; letter-spacing:0.2em; text-transform:uppercase; font-size:0.75rem; margin-bottom:1rem;">Core Capabilities</p>
					<h2 class="font-headline" style="font-size:clamp(2rem, 4vw, 3rem); font-weight:800; letter-spacing:-0.02em;">The NekoBeat Experience</h2>
				</div>
				<p style="color:#64748b; max-width:20rem; font-size:0.9375rem; line-height:1.6;">
					Redefining how you interact with your sound library through high-performance engineering.
				</p>
			</div>

			<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:1.5rem;">
				<!-- Feature Cards -->
				<div class="feature-card reveal" style="padding:2rem; border-radius:16px; display:flex; flex-direction:column; gap:1.5rem; cursor:pointer;">
					<div class="card-icon" style="width:3rem; height:3rem; border-radius:12px; background:rgba(225,29,72,0.15); display:flex; align-items:center; justify-content:center; color:var(--primary);">
						<span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">dataset</span>
					</div>
					<div>
						<h3 class="font-headline" style="font-size:1.25rem; font-weight:700; color:#f1f5f9; margin-bottom:0.75rem;">Universal Aggregation</h3>
						<p style="color:#94a3b8; font-size:0.875rem; line-height:1.7;">Search YouTube and SoundCloud from one unified, frictionless search portal powered by yt-dlp.</p>
					</div>
				</div>

				<div class="feature-card reveal" style="padding:2rem; border-radius:16px; display:flex; flex-direction:column; gap:1.5rem; cursor:pointer;">
					<div class="card-icon" style="width:3rem; height:3rem; border-radius:12px; background:rgba(3,181,211,0.15); display:flex; align-items:center; justify-content:center; color:var(--secondary);">
						<span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">cached</span>
					</div>
					<div>
						<h3 class="font-headline" style="font-size:1.25rem; font-weight:700; color:#f1f5f9; margin-bottom:0.75rem;">Offline Caching</h3>
						<p style="color:#94a3b8; font-size:0.875rem; line-height:1.7;">Liked songs are automatically cached to your local drive for zero-latency playback, even offline.</p>
					</div>
				</div>

				<div class="feature-card reveal" style="padding:2rem; border-radius:16px; display:flex; flex-direction:column; gap:1.5rem; cursor:pointer;">
