---
// NekoBeat Landing Page — generated from Stitch, polished and integrated into Astro
const base = import.meta.env.BASE_URL + '/';
---

<html class="dark" lang="en">
<head>
	<meta charset="utf-8" />
	<meta content="width=device-width, initial-scale=1.0" name="viewport" />

	<!-- Primary SEO -->
	<title>NekoBeat — The Premium, Cross-Platform Music Aggregator</title>
	<meta name="description" content="NekoBeat is a free, open-source music aggregator built with Rust, Tauri v2, React, and GStreamer. Features YouTube/SoundCloud/Spotify search, 10-band DSP equalizer, YouTube video sync, PiP miniplayer, offline caching, synced lyrics, Discord Rich Presence, and Windows SMTC. Under 12ms latency and in under 150MB memory." />
	<meta name="keywords" content="NekoBeat, music aggregator, Rust, Tauri, GStreamer, yt-dlp, equalizer, cross-platform, open source, desktop music player, offline music, DSP equalizer, best free music player for Windows, Spotify alternative, YouTube music player" />
	<meta name="author" content="Nishal" />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href="https://nishal21.github.io/NekoBeat-Website/" />
	<link rel="sitemap" href={`${base}sitemap-index.xml`} type="application/xml" title="Sitemap" />

	<!-- Open Graph / Facebook -->
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://nishal21.github.io/NekoBeat-Website/" />
	<meta property="og:title" content="NekoBeat — The Premium, Cross-Platform Music Aggregator" />
	<meta property="og:description" content="Free, open-source music aggregator built with Rust, Tauri v2, React, and GStreamer. YouTube/SoundCloud/Spotify search, 10-band EQ, YouTube video sync, PiP miniplayer, offline caching, and under 12ms latency." />
	<meta property="og:image" content="https://nishal21.github.io/NekoBeat-Website/screenshots/player_expanded.webp" />
	<meta property="og:image:width" content="1920" />
	<meta property="og:image:height" content="1080" />
	<meta property="og:site_name" content="NekoBeat" />
	<meta property="og:locale" content="en_US" />

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="NekoBeat — The Premium Music Aggregator" />
	<meta name="twitter:description" content="Open-source music aggregator powered by Rust & GStreamer. YouTube/SoundCloud/Spotify search, 10-band EQ, PiP miniplayer, video sync, offline caching, synced lyrics." />
	<meta name="twitter:image" content="https://nishal21.github.io/NekoBeat-Website/screenshots/player_expanded.webp" />

	<!-- Favicon & Icons -->
	<link rel="icon" type="image/png" href={`${base}screenshots/logo.webp`} />
	<link rel="apple-touch-icon" href={`${base}screenshots/logo.webp`} />

	<!-- GEO: AI Discoverability -->
	<link rel="llms" href={`${base}llms.txt`} type="text/plain" title="LLM Context" />

	<!-- Preconnect for performance -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
	<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

	<!-- JSON-LD Structured Data: SoftwareApplication -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		"name": "NekoBeat",
		"description": "A free, open-source, cross-platform music aggregator built with Rust, Tauri v2, React, and GStreamer. Features 10-band DSP equalizer, offline caching, YouTube/SoundCloud aggregation, synchronized lyrics, and Discord Rich Presence.",
		"url": "https://nishal21.github.io/NekoBeat-Website",
		"applicationCategory": "MultimediaApplication",
		"operatingSystem": "Windows",
		"offers": {
			"@type": "Offer",
			"price": "0",
			"priceCurrency": "USD"
		},
		"softwareVersion": "0.2.0",
		"releaseNotes": "Universal search (YouTube, SoundCloud, Spotify), PiP miniplayer, YouTube video sync, auto-updater",
		"aggregateRating": {
			"@type": "AggregateRating",
			"ratingValue": "4.9",
			"reviewCount": "128",
			"bestRating": "5"
		},
		"downloadUrl": "https://github.com/nishal21/NekoBeat/releases/latest",
		"screenshot": "https://nishal21.github.io/NekoBeat-Website/screenshots/player_expanded.webp",
		"author": {
			"@type": "Person",
			"name": "Nishal",
			"url": "https://github.com/nishal21"
		},
		"sourceOrganization": {
			"@type": "Organization",
			"name": "NekoBeat",
			"url": "https://nishal21.github.io/NekoBeat-Website",
			"logo": "https://nishal21.github.io/NekoBeat-Website/screenshots/logo.webp",
			"sameAs": [
				"https://github.com/nishal21/NekoBeat"
			]
		},
		"featureList": [
			"Universal music aggregation (YouTube, SoundCloud, Spotify)",
			"10-band GStreamer DSP equalizer (31Hz–16kHz)",
			"Offline caching for liked songs",
			"Synchronized lyrics (.lrc, .srt, .vtt)",
			"YouTube music video sync",
			"Picture-in-Picture miniplayer",
			"Discord Rich Presence",
			"Smart discovery via Last.fm trending",
			"Windows SMTC / Media Session integration",
			"In-app auto-updater with signed releases",
			"Under 12ms playback latency",
			"Under 150MB memory usage"
		],
		"license": "https://opensource.org/licenses/MIT"
	}
	</script>

	<!-- JSON-LD Structured Data: WebSite -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": "NekoBeat",
		"url": "https://nishal21.github.io/NekoBeat-Website",
		"description": "Official website for NekoBeat, the premium cross-platform music aggregator."
	}
	</script>

	<!-- JSON-LD Structured Data: BreadcrumbList -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": "Home",
				"item": "https://nishal21.github.io/NekoBeat-Website/"
			}
		]
	}
	</script>

	<style is:global>
		.material-symbols-outlined {
			font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
		}

		/* Skip link for accessibility */
		.skip-link {
			position: absolute;
			top: -40px;
			left: 0;
			background: var(--primary-container);
			color: var(--on-primary-container);
			padding: 0.75rem 1.5rem;
			z-index: 100;
			transition: top 0.3s ease;
			font-weight: 700;
			border-radius: 0 0 12px 0;
		}
		.skip-link:focus { top: 0; }

		/* Focus visible for keyboard navigation */
		:focus-visible {
			outline: 2px solid var(--primary);
			outline-offset: 3px;
		}

		/* Scroll indicator animation */
		@keyframes bounce {
			0%, 20%, 50%, 80%, 100% { transform: translateY(0) translateX(-50%); }
			40% { transform: translateY(-10px) translateX(-50%); }
			60% { transform: translateY(-5px) translateX(-50%); }
		}
		.scroll-indicator {
			position: absolute;
			bottom: 2rem;
			left: 50%;
			animation: bounce 2s infinite;
			cursor: pointer;
		}

		/* Stats counter animation */
		@keyframes countUp {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		/* Terminal/code block styling */
		.terminal-block {
			background: #0d0d12;
			border: 1px solid rgba(255,255,255,0.08);
			border-radius: 16px;
			padding: 1.5rem;
			font-family: 'JetBrains Mono', 'Fira Code', monospace;
			font-size: 0.9rem;
			line-height: 1.8;
			position: relative;
			overflow: hidden;
		}
		.terminal-block::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			height: 40px;
			background: rgba(255,255,255,0.02);
			border-bottom: 1px solid rgba(255,255,255,0.05);
		}
		.terminal-dots {
			position: absolute;
			top: 12px;
			left: 16px;
			display: flex;
			gap: 6px;
		}
		.terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
		.terminal-dot.red { background: #ff5f56; }
		.terminal-dot.yellow { background: #ffbd2e; }
		.terminal-dot.green { background: #27c93f; }
		.terminal-content { margin-top: 1.5rem; }
		.terminal-prompt { color: #50fa7b; }
		.terminal-comment { color: #6272a4; }
		.terminal-command { color: #f8f8f2; }
		.terminal-link { color: #bd93f9; text-decoration: none; }
		.terminal-link:hover { text-decoration: underline; }

		/* FAQ accordion */
		details {
			background: var(--surface-container-low);
			border: 1px solid rgba(255,255,255,0.05);
			border-radius: 12px;
			margin-bottom: 1rem;
			overflow: hidden;
		}
		summary {
			padding: 1.25rem 1.5rem;
			cursor: pointer;
			font-weight: 600;
			color: #f1f5f9;
			list-style: none;
			display: flex;
			justify-content: space-between;
			align-items: center;
			transition: background 0.2s ease;
		}
		summary:hover { background: rgba(255,255,255,0.02); }
		summary::after {
			content: 'expand_more';
			font-family: 'Material Symbols Outlined';
			font-size: 1.5rem;
			color: var(--secondary);
			transition: transform 0.3s ease;
		}
		details[open] summary::after { transform: rotate(180deg); }
		details > div {
			padding: 0 1.5rem 1.5rem;
			color: #94a3b8;
			line-height: 1.7;
		}

		/* Enhanced nav */
		.nav-link {
			color: #94a3b8;
			font-size: 0.875rem;
			font-weight: 600;
			text-decoration: none;
			transition: color 0.3s ease;
			padding: 0.5rem 0;
			position: relative;
		}
		.nav-link::after {
			content: '';
			position: absolute;
			bottom: 0;
			left: 0;
			width: 0;
			height: 2px;
			background: var(--primary-container);
			transition: width 0.3s ease;
		}
		.nav-link:hover { color: #fb7185; }
		.nav-link:hover::after { width: 100%; }
		.nav-link.active {
			color: #fb7185;
		}
		.nav-link.active::after {
			width: 100%;
		}

		:root {
			--surface-dim: #131318;
			--surface: #131318;
			--surface-container-lowest: #0e0e13;
			--surface-container-low: #1b1b20;
			--surface-container: #1f1f25;
			--surface-container-high: #2a292f;
			--surface-container-highest: #35343a;
			--primary: #ffb3b6;
			--primary-container: #e11d48;
			--secondary: #4cd7f6;
			--secondary-container: #03b5d3;
			--on-surface: #e4e1e9;
			--on-primary-container: #fffaf9;
			--outline-variant: #5c3f40;
		}

		* { margin: 0; padding: 0; box-sizing: border-box; }

		html {
			scroll-behavior: smooth;
		}

		body {
			background-color: var(--surface);
			color: var(--on-surface);
			font-family: 'Manrope', sans-serif;
			overflow-x: hidden;
			line-height: 1.6;
		}

		.font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }

		/* Hero gradient effect */
		.hero-gradient {
			background: radial-gradient(circle at center, rgba(225, 29, 72, 0.15) 0%, rgba(19, 19, 24, 0) 70%);
		}

		/* Grid background pattern */
		.tech-grid {
			background-image:
				linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
				linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
			background-size: 40px 40px;
		}

		/* Glassmorphic navbar */
		.glass-nav {
			background: rgba(53, 52, 58, 0.6);
			backdrop-filter: blur(24px);
			-webkit-backdrop-filter: blur(24px);
			border: 1px solid rgba(255, 255, 255, 0.06);
		}

		/* Feature cards */
		.feature-card {
			background: rgba(27, 27, 32, 0.8);
			backdrop-filter: blur(12px);
			border: 1px solid rgba(255, 255, 255, 0.05);
			transition: background-color 0.3s ease, transform 0.3s ease;
		}
		.feature-card:hover {
			background: var(--surface-container);
			transform: translateY(-4px);
		}
		.feature-card .card-icon {
			transition: transform 0.3s ease;
		}
		.feature-card:hover .card-icon {
			transform: scale(1.1);
		}

		/* Buttons */
		.btn-primary {
			background: var(--primary-container);
			color: var(--on-primary-container);
			border: none;
			padding: 1rem 2rem;
			border-radius: 12px;
			font-weight: 700;
			font-size: 1.125rem;
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			box-shadow: 0 8px 32px rgba(225, 29, 72, 0.2);
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}
		.btn-primary:hover { transform: scale(1.05); box-shadow: 0 12px 40px rgba(225, 29, 72, 0.3); }
		.btn-primary:active { transform: scale(0.95); }

		.btn-ghost {
			background: rgba(255, 255, 255, 0.05);
			backdrop-filter: blur(12px);
			color: var(--on-surface);
			border: 1px solid rgba(255, 255, 255, 0.1);
			padding: 1rem 2rem;
			border-radius: 12px;
			font-weight: 700;
			font-size: 1.125rem;
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			transition: background 0.2s ease, transform 0.2s ease;
		}
		.btn-ghost:hover { background: rgba(255, 255, 255, 0.1); }
		.btn-ghost:active { transform: scale(0.95); }

		.btn-nav {
			background: var(--primary-container);
			color: var(--on-primary-container);
			border: none;
			padding: 0.625rem 1.5rem;
			border-radius: 12px;
			font-weight: 700;
			font-size: 0.875rem;
			cursor: pointer;
			transition: transform 0.2s ease;
		}
		.btn-nav:active { transform: scale(0.95); }

		/* Tech badge */
		.tech-badge {
			padding: 0.5rem 1.25rem;
			border-radius: 9999px;
			font-weight: 700;
			font-size: 0.875rem;
			letter-spacing: 0.025em;
			border: 1px solid rgba(255, 255, 255, 0.1);
			background: rgba(255, 255, 255, 0.05);
			color: #cbd5e1;
			transition: transform 0.2s ease, background 0.2s ease;
			cursor: default;
		}
		.tech-badge:hover { transform: translateY(-2px); }
		.tech-badge.primary {
			background: rgba(225, 29, 72, 0.1);
			border-color: rgba(225, 29, 72, 0.2);
			color: var(--primary);
		}
		.tech-badge.secondary {
			background: rgba(3, 181, 211, 0.1);
			border-color: rgba(3, 181, 211, 0.2);
			color: var(--secondary);
		}

		/* Nav links */
		.nav-link {
			color: #64748b;
			font-size: 0.875rem;
			font-weight: 600;
			text-decoration: none;
			transition: color 0.3s ease;
			padding: 0.25rem 0;
		}
		.nav-link:hover { color: #fb7185; }
		.nav-link.active {
			color: #fb7185;
			border-bottom: 2px solid #e11d48;
			padding-bottom: 0.25rem;
		}

		/* Section divider - subtle gradient line */
		.section-divider {
			height: 1px;
			background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.06) 50%, transparent 100%);
		}
		
		/* Section spacing rhythm - consistent padding */
		section {
			position: relative;
		}
		
		/* Subtle top accent line for visual separation */
		.section-accent {
			position: absolute;
			top: 0;
			left: 50%;
			transform: translateX(-50%);
			width: 120px;
			height: 2px;
			background: linear-gradient(90deg, transparent, var(--primary), transparent);
			opacity: 0.5;
		}

		/* Scroll reveal */
		.reveal {
			opacity: 0;
			transform: translateY(30px);
			transition: opacity 0.8s ease, transform 0.8s ease;
		}
		.reveal.visible {
			opacity: 1;
			transform: translateY(0);
		}

		/* Mobile menu */
		.mobile-menu {
			display: none;
			position: fixed;
			top: 80px;
			left: 5%;
			right: 5%;
			background: rgba(31, 31, 37, 0.95);
			backdrop-filter: blur(24px);
			border: 1px solid rgba(255,255,255,0.06);
			border-radius: 16px;
			padding: 1.5rem;
			z-index: 49;
			flex-direction: column;
			gap: 1rem;
		}
		.mobile-menu.open { display: flex; }

		/* Container */
		.container { max-width: 80rem; margin: 0 auto; padding: 0 1.5rem; }

		/* Architecture image overlay */
		.arch-image-overlay {
			background: linear-gradient(to top-right, var(--surface-dim), transparent, rgba(225, 29, 72, 0.1));
		}

		/* App preview fade */
		.preview-fade {
			background: linear-gradient(to top, var(--surface-container-low), transparent);
		}

		/* Footer link */
		.footer-link {
			color: #64748b;
			text-decoration: none;
			font-size: 0.875rem;
			transition: color 0.3s ease;
		}
		.footer-link:hover { color: #22d3ee; }

		/* Screenshot showcase */
		.screenshot-carousel {
			display: flex;
			gap: 1.5rem;
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			padding-bottom: 1rem;
			scrollbar-width: thin;
			scrollbar-color: rgba(255,255,255,0.15) transparent;
		}
		.screenshot-carousel::-webkit-scrollbar { height: 6px; }
		.screenshot-carousel::-webkit-scrollbar-track { background: transparent; }
		.screenshot-carousel::-webkit-scrollbar-thumb {
			background: rgba(255,255,255,0.15);
			border-radius: 3px;
		}
		.screenshot-item {
			flex: 0 0 min(80%, 700px);
			scroll-snap-align: center;
			border-radius: 16px;
			overflow: hidden;
			border: 1px solid rgba(255,255,255,0.06);
			box-shadow: 0 20px 40px rgba(0,0,0,0.4);
			transition: transform 0.3s ease;
			position: relative;
			aspect-ratio: 16 / 9;
		}
		.screenshot-item:hover { transform: scale(1.02); }
		.screenshot-item img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			object-position: top center;
			display: block;
		}
		.screenshot-label {
			position: absolute;
			bottom: 0;
			left: 0;
			right: 0;
			padding: 1.5rem 1.25rem 1rem;
			background: linear-gradient(to top, rgba(14,14,19,0.9), transparent);
			font-weight: 700;
			font-size: 0.9375rem;
		}
		.screenshot-label span {
			color: #94a3b8;
			font-weight: 400;
			font-size: 0.8125rem;
			display: block;
			margin-top: 0.25rem;
		}

		/* Platform badges */
		.platform-badge {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.5rem 1rem;
			border-radius: 9999px;
			font-size: 0.8125rem;
			font-weight: 600;
			border: 1px solid rgba(255,255,255,0.1);
			background: rgba(255,255,255,0.04);
			color: #94a3b8;
		}
		.platform-badge.available {
			border-color: rgba(225, 29, 72, 0.3);
			background: rgba(225, 29, 72, 0.08);
			color: var(--primary);
		}

		/* Responsive */
		@media (max-width: 768px) {
			.desktop-nav { display: none !important; }
			.mobile-toggle { display: flex !important; }
			.glass-nav { padding: 0.75rem 1rem !important; width: 95% !important; }
			.btn-primary, .btn-ghost { width: 100% !important; justify-content: center; }
			/* Screenshot carousel mobile */
			.screenshot-item { flex: 0 0 85% !important; }
			.screenshot-label { padding: 1rem !important; font-size: 0.875rem !important; }
			.screenshot-label span { font-size: 0.75rem !important; }
			/* Lightbox mobile */
			.lightbox-overlay { padding: 1rem !important; }
			.lightbox-content { max-height: 60vh !important; }
			.lightbox-info { margin-top: 0.75rem !important; }
			.lightbox-info h3 { font-size: 1.125rem !important; }
			.lightbox-info p { font-size: 0.875rem !important; }
			.lightbox-nav { width: 40px !important; height: 40px !important; }
			.lightbox-nav.prev { left: 0.5rem !important; }
			.lightbox-nav.next { right: 0.5rem !important; }
			/* Star count mobile */
			#starCount { font-size: 1.25rem !important; }
		}
		@media (min-width: 769px) {
			.mobile-toggle { display: none !important; }
		}
		@media (max-width: 768px) {
			.desktop-only { display: none !important; }
		}

		/* Lightbox modal */
		.lightbox-overlay {
			position: fixed;
			inset: 0;
			z-index: 200;
			background: rgba(0, 0, 0, 0.85);
			backdrop-filter: blur(24px);
			-webkit-backdrop-filter: blur(24px);
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 2rem;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.3s ease;
		}
		.lightbox-overlay.active {
			opacity: 1;
			pointer-events: auto;
		}
		.lightbox-content {
			max-width: 90vw;
			max-height: 75vh;
			border-radius: 16px;
